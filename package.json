{
  "name": "wasm_sha256",
  "version": "2.6.0",
  "description": "Calculates the 256- or 244-bit SHA2 hash of a local file using SIMD acceleration",
  "type": "module",
  "main": "sha256sum.mjs",
  "scripts": {
    "compile:prod": "./utils/strip_debug.mjs && wat2wasm ./src/sha256.prod.wat -o ./bin/sha256.prod.wasm",
    "compile:dev": "                            wat2wasm ./src/sha256.wat      -o ./bin/sha256.dev.wasm",

    "opt:prod": "wasm-opt ./bin/sha256.prod.wasm --enable-simd --enable-multivalue --enable-bulk-memory -O4 -o ./bin/sha256.prod.opt.wasm",
    "opt:dev": "wasm-opt  ./bin/sha256.dev.wasm  --enable-simd --enable-multivalue --enable-bulk-memory -O4 -o ./bin/sha256.dev.opt.wasm",

    "build:prod": "npm run compile:prod && npm run opt:prod",
    "build:dev":  "npm run compile:dev  && npm run opt:dev",

    "clean": "rm -f ./bin/*.wasm && rm -f ./src/sha256.prod.wat && rm -f ./src/sha256.dev.wat"
  },
  "keywords": [
    "SHA256",
    "SIMD",
    "WebAssembly"
  ],
  "author": "Chris Whealy",
  "license": "MIT"
}
